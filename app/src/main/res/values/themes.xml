<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base app theme: no action bar, dark. Compose draws everything else. -->
    <style name="Theme.App" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/bg</item>
        <item name="android:statusBarColor">@color/bg</item>
        <item name="android:navigationBarColor">@color/bg</item>
    </style>

    <!-- Splash removes the white flash between launcher and app. Nothing more
         (spec §13.11): no animation, no branding, no slogan. -->
    <style name="Theme.App.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/bg</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_wind</item>
        <item name="postSplashScreenTheme">@style/Theme.App</item>
    </style>
</resources>
